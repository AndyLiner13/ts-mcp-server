{
  "compilerOptions": {
    "target": "ES2024",
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true
  },
  "include": ["index.ts", "tsserver.ts", "tools/**/*.ts"],
  "exclude": ["node_modules", "dist", "mcp-refactor-typescript"]
}
